# IssueRadar AI Production Environment Template

# System Environment
ENVIRONMENT="production"
PROJECT_NAME="IssueRadar AI"

# Backend Settings
API_PORT=8000
API_HOST="0.0.0.0"
CORS_ORIGINS="https://app.issueradar.ai,http://localhost"
FRONTEND_URL="https://app.issueradar.ai"

# PostgreSQL Production Credentials
POSTGRES_USER="issueradar_prod"
POSTGRES_PASSWORD="GENERATE_STRONG_PRODUCTION_PASSWORD"
POSTGRES_DB="issueradar_prod_db"
POSTGRES_HOST="postgres"
POSTGRES_PORT=5432
DATABASE_URL="postgresql+asyncpg://issueradar_prod:GENERATE_STRONG_PRODUCTION_PASSWORD@postgres:5432/issueradar_prod_db"

# Redis & Celery Production URLs
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_URL="redis://redis:6379/0"
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/0"

# GitHub OAuth Application Credentials
GITHUB_CLIENT_ID="your_production_github_client_id"
GITHUB_CLIENT_SECRET="your_production_github_client_secret"
GITHUB_REDIRECT_URI="https://app.issueradar.ai/api/v1/auth/callback"

# Security & Secrets
JWT_SECRET_KEY="GENERATE_HIGH_ENTROPY_RANDOM_SECRET_STRING_32_CHARS"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=10080
ENCRYPTION_KEY="GENERATE_FERNET_KEY_PYTHON_CRYPTOGRAPHY"

# AI Provider Configuration (mock | gemini | openai)
AI_PROVIDER="gemini"
GEMINI_API_KEY="your_google_gemini_api_key"
OPENAI_API_KEY="your_openai_api_key"

# Schedule Settings
SYNC_INTERVAL_DEFAULT="24h"
