# Global Configuration
PROJECT_NAME="IssueRadar AI"
ENVIRONMENT="development"

# FastAPI Backend Configuration
API_PORT=8000
API_HOST="0.0.0.0"
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000"
FRONTEND_URL="http://localhost:3000"

# React Frontend Configuration
VITE_API_BASE_URL="http://localhost:8000"

# PostgreSQL Configuration
POSTGRES_USER="issueradar"
POSTGRES_PASSWORD="issueradar_secret_password"
POSTGRES_DB="issueradar_db"
POSTGRES_HOST="postgres"
POSTGRES_PORT=5432
DATABASE_URL="postgresql+asyncpg://issueradar:issueradar_secret_password@postgres:5432/issueradar_db"

# Redis Configuration
REDIS_HOST="redis"
REDIS_PORT=6379
REDIS_URL="redis://redis:6379/0"

# GitHub OAuth Credentials
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GITHUB_REDIRECT_URI="http://localhost:8000/api/v1/auth/callback"

# Security & Authentication Configuration
JWT_SECRET_KEY="dev_secret_jwt_key_issueradar_ai_at_least_32_chars_long"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=10080

# Token Encryption Key (Fernet Key - generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY="xK9dJ_L2mN4pQ6rS8tV0wX2yZ4a6b8c0d2e4f6g8h0i="

# AI Provider Settings (mock | gemini | openai)
AI_PROVIDER="mock"
GEMINI_API_KEY=""
OPENAI_API_KEY=""

# Celery & Background Processing
CELERY_BROKER_URL="redis://redis:6379/0"
CELERY_RESULT_BACKEND="redis://redis:6379/0"
SYNC_INTERVAL_DEFAULT="24h"
